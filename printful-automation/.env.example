# Shopify webhook signing secret (Shopify admin -> Settings -> Notifications -> Webhooks)
SHOPIFY_WEBHOOK_SECRET=

# Shopify Admin API access token (Custom App, scopes: read_orders, read_products)
SHOPIFY_ADMIN_API_TOKEN=
SHOPIFY_STORE_DOMAIN=njthzk-fj.myshopify.com
